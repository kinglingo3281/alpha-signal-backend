# === Data Paths ===
# Directory containing per-symbol tracker JSON files
TRACKER_SYMBOL_DIR=/path/to/tracker/symbol

# Directory containing hl_trader_context_*.json files
HL_TRADER_STATE_DIR=/path/to/hl-trader/state

# Directory containing openclaw_agent_client.py (LLM client)
HL_TRADER_DIR=/path/to/hl-trader

# === LLM Settings ===
# OpenClaw agent ID for reasoning/analysis
ACP_ALPHA_AGENT_ID=acp-alpha-analyst
BEST_TRADE_AGENT_ID=acp-alpha-analyst
SYMBOL_SETUP_REASONING_AGENT_ID=acp-alpha-analyst

# Thinking level: low, medium, high
ACP_ALPHA_THINKING=medium
BEST_TRADE_THINKING=low
SYMBOL_SETUP_REASONING_THINKING=low

# Timeouts
ACP_ALPHA_TIMEOUT_SEC=45
BEST_TRADE_TIMEOUT_SEC=120
SYMBOL_SETUP_REASONING_TIMEOUT_SEC=30

# OpenClaw command (path to openclaw binary)
OPENCLAW_CMD=openclaw
